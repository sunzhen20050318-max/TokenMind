---
import { STRINGS, type Lang } from '../i18n/strings';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = STRINGS;

// Generic glyphs (chat / mail / send / etc.) keyed by channel name. We
// avoid platform brand marks here — each channel reads as a category
// indicator, with the channel name carrying the actual identification.
const glyphs: Record<string, string> = {
  Web:
    '<rect x="3.5" y="5" width="17" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M3.5 9h17M7 12h7M7 14.5h5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
  Telegram:
    '<path d="M3 11.5l17-6-3 14-5-3-2.5 3v-4.5L17 8 7 13z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>',
  WhatsApp:
    '<path d="M5 19l1.5-4A7 7 0 1 1 9 18.5z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 11c.5 1.5 1.5 2.5 3 3l1.2-.8 1.6.8.4 1.5c-2 .5-4-.4-5.5-1.8S8 10.5 8.5 8.5l1.5.4.8 1.6z" fill="currentColor"/>',
  Email:
    '<rect x="3.5" y="5.5" width="17" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="m3.5 7.5 8.5 6 8.5-6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>',
  Feishu:
    '<path d="M5 9c2 0 5-3 7-3s5 3 7 3-3 7-7 9c-4-2-9-9-7-9z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>',
  DingTalk:
    '<path d="M12 4l8 5v6l-8 5-8-5V9z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 11l2.5 2.5L15 10" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>',
  WeCom:
    '<path d="M4 9.5c0-2.2 2.7-4 6-4s6 1.8 6 4c0 1.5-1.3 2.8-3.2 3.5L13 16l-2.5-2c-3.6 0-6.5-1.9-6.5-4.5z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><circle cx="9" cy="9.5" r="1" fill="currentColor"/><circle cx="13" cy="9.5" r="1" fill="currentColor"/>',
  QQ:
    '<path d="M8 4.5c-2 1-3 3-3 5.5 0 1.2.4 2.2 1 3-.5.5-1 1.5-1 2.5l2-.5c.7 1.5 2.5 2.5 5 2.5s4.3-1 5-2.5l2 .5c0-1-.5-2-1-2.5.6-.8 1-1.8 1-3 0-2.5-1-4.5-3-5.5-1-.5-2.3-.8-4-.8s-3 .3-4 .8z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><circle cx="9.5" cy="10" r="0.9" fill="currentColor"/><circle cx="14.5" cy="10" r="0.9" fill="currentColor"/>',
};
---

<section
  id="channels"
  class="relative bg-[color:var(--color-ink-50)]/60 px-6 py-28 sm:py-32 lg:py-40"
  aria-label={t.channels.title[lang]}
>
  <div class="mx-auto max-w-6xl">
    <header data-reveal class="mb-14 max-w-2xl sm:mb-16">
      <div
        class="mb-3 inline-flex items-center gap-2 text-[10px] font-semibold uppercase tracking-[0.28em] text-[color:var(--color-muted)]"
      >
        <span class="h-px w-6 bg-[color:var(--color-line-strong)]"></span>
        {t.channels.eyebrow[lang]}
      </div>
      <h2
        class="wordmark-display mb-4 text-[clamp(2rem,4vw,3.4rem)] leading-[1.05] text-[color:var(--color-fg)]"
      >
        {t.channels.title[lang]}
      </h2>
      <p
        class="text-base leading-relaxed text-[color:var(--color-muted)] sm:text-lg"
      >
        {t.channels.body[lang]}
      </p>
    </header>

    <ul
      data-reveal-pop
      class="grid grid-cols-2 gap-3 sm:grid-cols-4 sm:gap-4 lg:grid-cols-4"
    >
      {
        t.channels.items.map((item) => (
          <li>
            <div
              class="group flex h-full flex-col items-center gap-3 rounded-xl border border-[color:var(--color-line-strong)]/70 bg-[color:var(--color-surface)] p-5 text-center transition-all duration-200 hover:-translate-y-0.5 hover:border-[color:var(--color-fg)]/40 hover:shadow-[0_12px_28px_-18px_rgba(10,10,10,0.25)] sm:p-6"
            >
              <span
                class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-[color:var(--color-ink-50)] text-[color:var(--color-fg)] transition-colors duration-200 group-hover:bg-[color:var(--color-fg)] group-hover:text-[color:var(--color-surface)]"
              >
                <svg
                  viewBox="0 0 24 24"
                  class="h-6 w-6"
                  aria-hidden="true"
                  set:html={glyphs[item.name]}
                />
              </span>
              <div class="flex flex-col items-center gap-1">
                <span
                  class="text-[14px] font-semibold tracking-tight text-[color:var(--color-fg)]"
                >
                  {item.name}
                </span>
                <span
                  class="text-[11px] font-medium uppercase tracking-[0.18em] text-[color:var(--color-subtle)]"
                >
                  {item.tag[lang]}
                </span>
              </div>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>
