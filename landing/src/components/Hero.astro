---
import { INSTALLERS } from '../lib/downloads';
import { STRINGS, type Lang } from '../i18n/strings';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = STRINGS;
---

<!--
  Hero. Light canvas, monochrome typography, two download CTAs.
  Brand cluster (mark + "TokenMind") is the focal point — supersized so it
  reads as the page wordmark. Headline below is a one-line subtitle.
  Content sits in the upper third (justify-start + responsive top padding)
  so users land "looking down" the page instead of dead-center.
-->
<section
  class="relative flex min-h-[100dvh] flex-col items-center justify-center overflow-hidden px-6 pt-24"
>
  <!-- Subtle grid backdrop, almost invisible — adds depth without color. -->
  <div
    class="pointer-events-none absolute inset-0 grid-lines opacity-[0.55] [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_75%)]"
    aria-hidden="true"
  ></div>

  <div class="relative flex flex-col items-center gap-7 sm:gap-8 xl:gap-10 2xl:gap-12">
    <!-- Brand cluster: oversized mark + wordmark sit together as the page's
         primary visual. The wordmark is split into per-character spans on
         load and typewriter-revealed. -->
    <div class="flex items-center gap-4 sm:gap-5 xl:gap-7 2xl:gap-8">
      <img
        data-hero-mark
        src="/tokenmind-mark-black.svg"
        alt=""
        width="96"
        height="96"
        class="h-14 w-auto sm:h-20 md:h-24 lg:h-28 xl:h-36 2xl:h-44"
        draggable="false"
      />
      <span
        data-hero-wordmark
        class="wordmark-display text-5xl text-[color:var(--color-fg)] sm:text-7xl md:text-8xl lg:text-[8.5rem] xl:text-[10.5rem] 2xl:text-[13rem]"
      >
        TokenMind
      </span>
    </div>

    <!-- Subtitle. One line on desktop, wraps on mobile. Word-level reveal
         lives in heroAnimations.ts. -->
    <h1
      data-hero-headline
      class="max-w-3xl text-balance text-center text-xl font-medium leading-[1.25] tracking-tight text-[color:var(--color-fg)] sm:text-2xl md:text-3xl xl:max-w-4xl xl:text-4xl 2xl:max-w-5xl 2xl:text-[2.75rem]"
    >
      {t.hero.headline[lang]}
    </h1>

    <p
      data-hero-tagline
      class="max-w-xl text-center text-sm text-[color:var(--color-muted)] sm:text-base xl:max-w-2xl xl:text-lg 2xl:max-w-3xl 2xl:text-xl"
    >
      {t.hero.tagline[lang]}
    </p>

    <!-- Two CTAs: macOS + Windows. Direct download links, no intermediary
         page. -->
    <div class="mt-2 flex flex-col items-center gap-3 sm:flex-row sm:gap-4 xl:mt-4 xl:gap-5">
      {
        INSTALLERS.macos ? (
          <a
            data-hero-cta
            href={INSTALLERS.macos}
            download
            class="group inline-flex items-center gap-2 rounded-full bg-[color:var(--color-fg)] px-6 py-2.5 text-sm font-medium text-[color:var(--color-surface)] transition-colors duration-200 hover:bg-[color:var(--color-ink-700)] xl:gap-2.5 xl:px-8 xl:py-3.5 xl:text-base 2xl:px-10 2xl:py-4 2xl:text-lg"
          >
            <svg viewBox="0 0 24 24" class="h-4 w-4 xl:h-[18px] xl:w-[18px] 2xl:h-5 2xl:w-5" fill="currentColor" aria-hidden="true">
              <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09Zm-5.03-16.05c.14-2.21 1.94-4.04 4.06-4.23.27 2.39-1.77 4.34-4.06 4.23Z" />
            </svg>
            {t.hero.macos[lang]}
          </a>
        ) : null
      }
      {
        INSTALLERS.windows ? (
          <a
            data-hero-cta
            href={INSTALLERS.windows}
            download
            class="group inline-flex items-center gap-2 rounded-full border border-[color:var(--color-line-strong)] bg-transparent px-6 py-2.5 text-sm font-medium text-[color:var(--color-fg)] transition-colors duration-200 hover:bg-[color:var(--color-ink-50)] xl:gap-2.5 xl:px-8 xl:py-3.5 xl:text-base 2xl:px-10 2xl:py-4 2xl:text-lg"
          >
            <svg viewBox="0 0 24 24" class="h-4 w-4 xl:h-[18px] xl:w-[18px] 2xl:h-5 2xl:w-5" fill="currentColor" aria-hidden="true">
              <path d="M2.5 5.2 11 4v8.2H2.5zM2.5 12.8h8.5V21l-8.5-1.2zM11.75 3.85 21.5 2.4v9.8H11.75zM11.75 12.8H21.5v9.8l-9.75-1.45z" />
            </svg>
            {t.hero.windows[lang]}
          </a>
        ) : null
      }
    </div>
  </div>

  <!-- Scroll cue, sits absolute bottom-center; opacity is animated last in
       the entrance timeline so it's the final element to settle. -->
  <div
    data-hero-scroll-cue
    class="absolute bottom-10 left-1/2 -translate-x-1/2 text-xs uppercase tracking-[0.32em] text-[color:var(--color-subtle)] xl:text-sm 2xl:text-base"
    aria-hidden="true"
  >
    {t.hero.scroll[lang]}
  </div>
</section>

<script>
  // Run the entrance choreography on the next paint so transformed initial
  // styles are committed first; otherwise GSAP can race CSS and produce a
  // single-frame flash of un-transformed content.
  import { playHeroIntro } from '../lib/heroAnimations';

  requestAnimationFrame(() => {
    playHeroIntro();
  });
</script>
