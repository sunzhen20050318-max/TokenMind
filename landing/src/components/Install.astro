---
/**
 * Final download CTA. Pure black canvas with a uniform white particle
 * field that fills the section background.
 *
 * Layout: section-level eyebrow + headline anchor the TOP-LEFT. The
 * download area below splits into TWO COLUMNS — Windows on the left
 * (left-aligned within its column), macOS on the right (right-aligned
 * within its column). Each column has a small platform label and a
 * single download button.
 *
 * Interaction: as the cursor enters the LEFT half of the section, the
 * particles assemble into a large `{` `}` pair that wraps the Windows
 * column. The RIGHT half does the same for macOS. Either side can be
 * active at a time; crossing the centre deadband swaps the formation
 * with a smooth spring transition. Both the geometry and physics live
 * in `lib/installParticles.ts`.
 */
import { INSTALLERS } from '../lib/downloads';
import { STRINGS, type Lang } from '../i18n/strings';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = STRINGS;

// Apple logo, fits within viewBox 0–24 (the previous path had negative
// coordinates and ran past y=24, so the glyph was clipped).
const macosGlyph =
  '<path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09Zm-5.03-16.05c.14-2.21 1.94-4.04 4.06-4.23.27 2.39-1.77 4.34-4.06 4.23Z" fill="currentColor"/>';
// Classic Windows "flag" logo (Windows 8+ style) — four parallelogram
// tiles with a slight perspective tilt: the top edges of the upper
// tiles slope up to the right and the bottom edges of the lower tiles
// slope down to the right, producing the rippling-flag look that the
// flat 4-square version was missing.
const windowsGlyph =
  '<path d="M2.5 5.2 11 4v8.2H2.5zM2.5 12.8h8.5V21l-8.5-1.2zM11.75 3.85 21.5 2.4v9.8H11.75zM11.75 12.8H21.5v9.8l-9.75-1.45z" fill="currentColor"/>';
---

<section
  id="install"
  data-install-section
  class="install-section relative overflow-hidden bg-[color:var(--color-fg)] px-6 pb-32 pt-10 text-[color:var(--color-surface)] sm:px-10 sm:pb-40 sm:pt-12 lg:px-16 lg:pb-44 lg:pt-16 xl:px-24 2xl:px-32"
  aria-label={t.install.title[lang]}
>
  <!-- Particle field. Section-scoped canvas behind everything else. -->
  <canvas
    data-install-canvas
    class="pointer-events-none absolute inset-0 h-full w-full"
    aria-hidden="true"
  ></canvas>

  <!-- Header pinned to the section's TOP-LEFT corner. Lives outside the
       centered container so its left edge sits at the section's padding,
       not at the centered container's left edge. -->
  <header class="relative max-w-2xl">
    <div
      class="mb-4 inline-flex items-center gap-2 text-[10px] font-semibold uppercase tracking-[0.32em] text-white/55"
    >
      <span class="h-px w-6 bg-white/30"></span>
      {t.install.eyebrow[lang]}
    </div>
    <h2
      class="wordmark-display text-[clamp(2.2rem,5vw,4rem)] leading-[1.02] tracking-tight"
    >
      {t.install.title[lang]}
    </h2>
  </header>

  <div class="relative mx-auto mt-24 max-w-6xl sm:mt-32 lg:mt-40 xl:max-w-[1400px] 2xl:max-w-[1600px]">
    <!-- Two-column download grid. Each column hosts a centred card; the
         brace formation wraps the active card. -->
    <div
      class="grid grid-cols-1 gap-16 sm:grid-cols-2 sm:gap-12 lg:gap-20"
    >
      {/* Each side is a CENTERED CARD inside its half. The `data-install-col`
          attribute is on the inner wrapper (not the grid cell) so the
          particle script measures the actual content footprint, and the
          brace lands snugly around that card — matching the Antigravity
          reference where the brace pair flanks a compact column of
          centered content, not the entire half-section. */}
      {
        INSTALLERS.windows ? (
          <div class="flex justify-center">
            <div
              data-install-col="left"
              class="install-col flex max-w-[360px] flex-col items-center gap-6 text-center"
            >
              <div class="flex items-center gap-2.5">
                <svg
                  viewBox="0 0 24 24"
                  class="h-5 w-5 text-white/85"
                  aria-hidden="true"
                  set:html={windowsGlyph}
                />
                <span class="text-[11px] font-semibold uppercase tracking-[0.28em] text-white/70">
                  Windows
                </span>
              </div>
              <h3 class="text-[clamp(1.7rem,2.8vw,2.4rem)] font-semibold leading-[1.1] tracking-tight text-white">
                {t.install.windowsLabel[lang]}
              </h3>
              <p class="text-[14px] leading-relaxed text-white/55">
                {t.install.windowsHint[lang]}
              </p>
              <a
                href={INSTALLERS.windows}
                download
                data-install-button="left"
                class="install-btn mt-2 inline-flex items-center gap-2.5 rounded-full border border-white/35 bg-transparent px-8 py-3.5 text-[15px] font-medium text-white transition-colors duration-200 hover:border-white hover:bg-white hover:text-black"
              >
                <span aria-hidden="true">↓</span>
                Download
              </a>
            </div>
          </div>
        ) : null
      }

      {
        INSTALLERS.macos ? (
          <div class="flex justify-center">
            <div
              data-install-col="right"
              class="install-col flex max-w-[360px] flex-col items-center gap-6 text-center"
            >
              <div class="flex items-center gap-2.5">
                <svg
                  viewBox="0 0 24 24"
                  class="h-5 w-5 text-white/85"
                  aria-hidden="true"
                  set:html={macosGlyph}
                />
                <span class="text-[11px] font-semibold uppercase tracking-[0.28em] text-white/70">
                  macOS
                </span>
              </div>
              <h3 class="text-[clamp(1.7rem,2.8vw,2.4rem)] font-semibold leading-[1.1] tracking-tight text-white">
                {t.install.macosLabel[lang]}
              </h3>
              <p class="text-[14px] leading-relaxed text-white/55">
                {t.install.macosHint[lang]}
              </p>
              <a
                href={INSTALLERS.macos}
                download
                data-install-button="right"
                class="install-btn mt-2 inline-flex items-center gap-2.5 rounded-full border border-white/35 bg-transparent px-8 py-3.5 text-[15px] font-medium text-white transition-colors duration-200 hover:border-white hover:bg-white hover:text-black"
              >
                <span aria-hidden="true">↓</span>
                Download
              </a>
            </div>
          </div>
        ) : null
      }
    </div>
  </div>
</section>

<style>
  /* Lift the button on hover so the brace formation visibly tracks it. */
  .install-btn {
    will-change: transform;
    transition:
      transform 220ms ease,
      background-color 200ms ease,
      border-color 200ms ease,
      color 200ms ease;
  }
  .install-btn:hover {
    transform: translateY(-2px);
  }
</style>
