---
import { LINKS } from '../lib/links';
import { STRINGS, type Lang } from '../i18n/strings';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = STRINGS;

// Footer is brand-led, modeled after Antigravity-style: a short tagline
// at the top-left, two flat lists of plain links (no column headers, no
// translated category names), then a HUGE wordmark across the page, and
// a thin meta strip at the very bottom. Link labels stay English in
// both routes — they're product-facing nouns that read the same in
// either, and skipping translation keeps the footer visually anchored
// to the brand.
// Resolve a link key to its URL. Each link entry in strings.ts carries
// both the (translated) label AND a stable key — the URL lookup goes
// through the key so labels can be freely renamed per language.
const linkHref = (key: string): string => {
  switch (key) {
    case 'download':
      return '#install';
    case 'docs':
      return `${LINKS.github}/blob/main/README.md`;
    case 'github':
      return LINKS.github;
    case 'gitee':
      return LINKS.gitee;
    case 'license':
    case 'mitLicense':
      return `${LINKS.github}/blob/main/LICENSE`;
    case 'changelog':
      return `${LINKS.github}/releases`;
    case 'contact':
      return `mailto:${LINKS.email}`;
    case 'privacy':
      return `${LINKS.github}/blob/main/SECURITY.md`;
    default:
      return '#';
  }
};
const isExternal = (href: string) =>
  href.startsWith('http') && !href.startsWith(`${LINKS.github}/blob/main/README`);
---

<footer
  class="relative overflow-hidden border-t border-[color:var(--color-line-soft)] bg-[color:var(--color-surface)]"
>
  <!-- Top region: tagline (LEFT) + two flat link columns sit in a
       single horizontal row, modeled on the Antigravity footer
       (image 20). The link columns sit roughly center / right-center
       so the row reads as: short anchor phrase on the left, link
       directory on the right — not a "filler band" pushed all the
       way to the viewport edge. -->
  <div class="px-6 pt-12 pb-8 sm:px-10 sm:pt-16 sm:pb-10 lg:px-16 lg:pt-14 xl:px-24 xl:pt-14 2xl:px-32 2xl:pt-16">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-[1.4fr_1fr_1fr]">
      <p
        class="max-w-md text-[clamp(1.4rem,2.2vw,2rem)] font-semibold leading-[1.15] tracking-tight text-[color:var(--color-fg)]"
      >
        {t.footer.tagline[lang]}
      </p>

      <ul class="flex flex-col gap-3 text-[15px]">
        {
          t.footer.primaryLinks.map((link) => {
            const href = linkHref(link.key);
            return (
              <li>
                <a
                  href={href}
                  target={isExternal(href) ? '_blank' : undefined}
                  rel={
                    isExternal(href) ? 'noopener noreferrer' : undefined
                  }
                  class="text-[color:var(--color-fg)] transition-colors duration-150 hover:text-[color:var(--color-muted)]"
                >
                  {link.label[lang]}
                </a>
              </li>
            );
          })
        }
      </ul>

      <ul class="flex flex-col gap-3 text-[15px]">
        {
          t.footer.secondaryLinks.map((link) => {
            const href = linkHref(link.key);
            return (
              <li>
                <a
                  href={href}
                  target={isExternal(href) ? '_blank' : undefined}
                  rel={
                    isExternal(href) ? 'noopener noreferrer' : undefined
                  }
                  class="text-[color:var(--color-fg)] transition-colors duration-150 hover:text-[color:var(--color-muted)]"
                >
                  {link.label[lang]}
                </a>
              </li>
            );
          })
        }
      </ul>
    </div>
  </div>

  <!-- HUGE brand wordmark, separated from the top row by a deliberate
       gap (Antigravity-style: top directory band + dramatic empty
       interval + monumental wordmark anchor at the bottom). The
       wordmark is purely decorative; the brand link lives in the
       meta strip below. -->
  <div
    class="pointer-events-none select-none px-6 pb-4 pt-2 sm:px-10 lg:px-16 xl:px-24 2xl:px-32"
    aria-hidden="true"
  >
    <div
      class="wordmark-display text-[color:var(--color-fg)]"
      style="font-size: clamp(3rem, 18vw, 22rem); line-height: 0.9; letter-spacing: -0.04em;"
    >
      TokenMind
    </div>
  </div>

  <!-- Meta strip: small brand mark on the left, version + bullet-separated
       legal links on the right. -->
  <div class="border-t border-[color:var(--color-line-soft)]">
    <div
      class="flex flex-col items-start gap-3 px-6 py-5 sm:flex-row sm:items-center sm:justify-between sm:px-10 sm:py-6 lg:px-16 xl:px-24 2xl:px-32"
    >
      <a
        href={lang === 'zh' ? '/' : '/en/'}
        class="flex items-center gap-2 text-[color:var(--color-fg)] transition-opacity duration-150 hover:opacity-70"
        aria-label={t.nav.homeLabel[lang]}
      >
        <img
          src="/tokenmind-mark-black.svg"
          alt=""
          width="20"
          height="20"
          class="h-4 w-auto"
          draggable="false"
        />
        <span class="text-[13px] font-medium tracking-tight">TokenMind</span>
      </a>

      <ul
        class="flex flex-wrap items-center gap-x-4 gap-y-2 text-[12px] text-[color:var(--color-muted)]"
      >
        {
          t.footer.metaLinks.map((link, i) => {
            const href = linkHref(link.key);
            return (
              <li class="flex items-center gap-x-4">
                {i > 0 ? (
                  <span
                    class="text-[color:var(--color-line-strong)]"
                    aria-hidden="true"
                  >
                    ·
                  </span>
                ) : null}
                <a
                  href={href}
                  target={isExternal(href) ? '_blank' : undefined}
                  rel={
                    isExternal(href) ? 'noopener noreferrer' : undefined
                  }
                  class="transition-colors duration-150 hover:text-[color:var(--color-fg)]"
                >
                  {link.label[lang]}
                </a>
              </li>
            );
          })
        }
        <li class="flex items-center gap-x-4">
          <span
            class="text-[color:var(--color-line-strong)]"
            aria-hidden="true"
          >
            ·
          </span>
          <a
            href="https://beian.miit.gov.cn/"
            target="_blank"
            rel="noopener noreferrer"
            class="transition-colors duration-150 hover:text-[color:var(--color-fg)]"
          >
            {t.footer.icp}
          </a>
        </li>
      </ul>
    </div>
  </div>
</footer>
