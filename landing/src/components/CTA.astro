---
import { INSTALLERS } from '../lib/downloads';
import { STRINGS, type Lang } from '../i18n/strings';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = STRINGS;
---

<section
  id="download"
  class="relative px-6 py-28 sm:py-32 lg:py-40"
  aria-label={t.cta.title[lang]}
>
  <div
    data-reveal-stagger
    class="mx-auto flex max-w-3xl flex-col items-center gap-8 text-center"
  >
    <h2
      class="wordmark-display text-[clamp(2.2rem,5vw,4rem)] leading-[1.04] text-[color:var(--color-fg)]"
    >
      {t.cta.title[lang]}
    </h2>
    <p
      class="max-w-xl text-base leading-relaxed text-[color:var(--color-muted)] sm:text-lg"
    >
      {t.cta.body[lang]}
    </p>

    <div class="mt-2 flex flex-col items-center gap-3 sm:flex-row sm:gap-4">
      {
        INSTALLERS.macos ? (
          <a
            href={INSTALLERS.macos}
            download
            class="inline-flex items-center gap-2 rounded-full bg-[color:var(--color-fg)] px-7 py-3 text-sm font-medium text-[color:var(--color-surface)] transition-colors duration-200 hover:bg-[color:var(--color-ink-700)]"
          >
            <svg
              viewBox="0 0 24 24"
              class="h-4 w-4"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M16.365 1.43c0 1.14-.493 2.27-1.177 3.08-.744.9-1.99 1.57-2.987 1.57-.12-1.103.42-2.24 1.114-2.99.793-.88 2.135-1.575 3.05-1.66Zm4.565 17.39c-.745 1.71-1.107 2.45-2.066 3.97-1.339 2.07-3.245 4.65-5.578 4.66-2.13.02-2.677-1.4-5.567-1.4-2.89.01-3.49 1.42-5.62 1.4-2.336-.04-4.135-2.36-5.476-4.43C-1.65 17.84-1.91 12.86 1.6 9.83c1.94-1.71 4.32-2.59 6.46-2.59 1.86 0 3.04.99 4.6.99 1.55 0 2.49-.99 4.65-.99 1.65 0 3.41.9 4.66 2.46-4.1 2.25-3.43 8.13.96 8.12Z" />
            </svg>
            {t.hero.macos[lang]}
          </a>
        ) : null
      }
      {
        INSTALLERS.windows ? (
          <a
            href={INSTALLERS.windows}
            download
            class="inline-flex items-center gap-2 rounded-full border border-[color:var(--color-line-strong)] bg-transparent px-7 py-3 text-sm font-medium text-[color:var(--color-fg)] transition-colors duration-200 hover:bg-[color:var(--color-ink-50)]"
          >
            <svg
              viewBox="0 0 24 24"
              class="h-4 w-4"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M0 3.5 9.75 2v9.5H0Zm0 17V11.5h9.75V22ZM10.75 11.5H24V22l-13.25-1.5Zm0-9.5L24 0v11h-13.25Z" />
            </svg>
            {t.hero.windows[lang]}
          </a>
        ) : null
      }
    </div>
  </div>
</section>
