---
/**
 * Three-pillar accordion. Tools / Channels / Memory each occupy one card.
 *
 * Three states (driven by `data-state` on each card, set by JS):
 * - "rest":  three cards equal width, kicker + title + body visible.
 * - "active": this card is hovered/tapped, expands to ~3x width, items grid revealed.
 * - "strip":  a sibling is active, this card squeezed to a narrow strip showing
 *             only the icon + a vertical kicker label.
 *
 * Entrance animation: middle card slides down from above, side cards slide up
 * from below, the trio snaps into a row. Wired in `lib/featureTrio.ts`.
 */
import { STRINGS, type Lang } from '../i18n/strings';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = STRINGS;

// Pillar-level glyphs — one mark per card, shown in both rest and strip
// states. Kept abstract (geometric forms) to read as a category, not a brand.
const pillarIcons: Record<'tools' | 'channels' | 'memory', string> = {
  tools:
    '<rect x="4.5" y="4.5" width="6.5" height="6.5" rx="1.2" fill="none" stroke="currentColor" stroke-width="1.6"/><rect x="13" y="4.5" width="6.5" height="6.5" rx="1.2" fill="none" stroke="currentColor" stroke-width="1.6"/><rect x="4.5" y="13" width="6.5" height="6.5" rx="1.2" fill="none" stroke="currentColor" stroke-width="1.6"/><rect x="13" y="13" width="6.5" height="6.5" rx="1.2" fill="none" stroke="currentColor" stroke-width="1.6"/>',
  channels:
    '<path d="M4 7h16M4 12h16M4 17h11" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><circle cx="17.5" cy="17" r="2.3" fill="currentColor"/>',
  memory:
    '<rect x="5" y="5.5" width="14" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="M9 9.5h6M9 12.5h6M9 15.5h4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>',
};

// Sub-item glyphs — keyed by item name (zh) for tools and by channel
// name for channels, and by `key` for memory items. Same visual language
// as the previous standalone sections so the cards feel familiar.
const toolGlyphs: Record<string, string> = {
  'Shell 命令':
    '<path d="M4 5l4 4-4 4M11 13h7" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>',
  文件系统:
    '<path d="M5 6.5A1.5 1.5 0 0 1 6.5 5h3l1.4 1.5h6.6A1.5 1.5 0 0 1 19 8v8.5A1.5 1.5 0 0 1 17.5 18h-11A1.5 1.5 0 0 1 5 16.5z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>',
  Web: '<circle cx="12" cy="12" r="7" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M5 12h14M12 5c2.5 2.6 2.5 11.4 0 14M12 5c-2.5 2.6-2.5 11.4 0 14" fill="none" stroke="currentColor" stroke-width="1.5"/>',
  MCP: '<path d="M5 8.5h14M5 12h14M5 15.5h14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><circle cx="8" cy="8.5" r="1.1" fill="currentColor"/><circle cx="14" cy="12" r="1.1" fill="currentColor"/><circle cx="10" cy="15.5" r="1.1" fill="currentColor"/>',
  知识库:
    '<path d="M6 5h9a3 3 0 0 1 3 3v11l-3-1.5-3 1.5-3-1.5-3 1.5z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 9h6M9 12h4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
  记忆系统:
    '<rect x="5" y="6" width="14" height="12" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M9 10h6M9 13h4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M3 9v2M3 13v2M21 9v2M21 13v2" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
  定时任务:
    '<circle cx="12" cy="12" r="7" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M12 8v4l2.5 1.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>',
  创作能力:
    '<path d="M12 5l1.8 4.2L18 11l-4.2 1.8L12 17l-1.8-4.2L6 11l4.2-1.8z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>',
};

const channelGlyphs: Record<string, string> = {
  Web: '<rect x="3.5" y="5" width="17" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M3.5 9h17M7 12h7M7 14.5h5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
  Telegram:
    '<path d="M3 11.5l17-6-3 14-5-3-2.5 3v-4.5L17 8 7 13z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>',
  WhatsApp:
    '<path d="M5 19l1.5-4A7 7 0 1 1 9 18.5z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>',
  Email:
    '<rect x="3.5" y="5.5" width="17" height="13" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="m3.5 7.5 8.5 6 8.5-6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>',
  Feishu:
    '<path d="M5 9c2 0 5-3 7-3s5 3 7 3-3 7-7 9c-4-2-9-9-7-9z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>',
  DingTalk:
    '<path d="M12 4l8 5v6l-8 5-8-5V9z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M9 11l2.5 2.5L15 10" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>',
  WeCom:
    '<path d="M4 9.5c0-2.2 2.7-4 6-4s6 1.8 6 4c0 1.5-1.3 2.8-3.2 3.5L13 16l-2.5-2c-3.6 0-6.5-1.9-6.5-4.5z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><circle cx="9" cy="9.5" r="1" fill="currentColor"/><circle cx="13" cy="9.5" r="1" fill="currentColor"/>',
  QQ: '<path d="M8 4.5c-2 1-3 3-3 5.5 0 1.2.4 2.2 1 3-.5.5-1 1.5-1 2.5l2-.5c.7 1.5 2.5 2.5 5 2.5s4.3-1 5-2.5l2 .5c0-1-.5-2-1-2.5.6-.8 1-1.8 1-3 0-2.5-1-4.5-3-5.5-1-.5-2.3-.8-4-.8s-3 .3-4 .8z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><circle cx="9.5" cy="10" r="0.9" fill="currentColor"/><circle cx="14.5" cy="10" r="0.9" fill="currentColor"/>',
};

const memoryGlyphs: Record<string, string> = {
  'long-term':
    '<rect x="5" y="5" width="14" height="14" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M9 9h6M9 12h6M9 15h4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>',
  history:
    '<path d="M5 12h14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="8" cy="12" r="1.4" fill="currentColor"/><circle cx="12" cy="12" r="1.4" fill="currentColor"/><circle cx="16" cy="12" r="1.4" fill="currentColor"/>',
  auto: '<path d="M5 12a7 7 0 0 1 12-5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M19 12a7 7 0 0 1-12 5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M17 4v3.5h-3.5M7 20v-3.5h3.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>',
  plain:
    '<path d="M5 19l3-1 9-9-3-3-9 9z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M14 6l3 3" fill="none" stroke="currentColor" stroke-width="1.5"/>',
};

// The three cards in DOM order: tools (left) · channels (center) · memory (right).
// Order matters: the entrance animation treats index 1 as the center card.
const cards = [
  {
    key: 'tools' as const,
    meta: t.featureTrio.cards.tools,
    items: t.tools.items.map((item) => ({
      name: item.name,
      desc: item.desc,
      glyph: toolGlyphs[item.name.zh] ?? '',
    })),
  },
  {
    key: 'channels' as const,
    meta: t.featureTrio.cards.channels,
    items: t.channels.items.map((item) => ({
      name: { zh: item.name, en: item.name },
      desc: item.tag,
      glyph: channelGlyphs[item.name] ?? '',
    })),
  },
  {
    key: 'memory' as const,
    meta: t.featureTrio.cards.memory,
    items: t.featureTrio.cards.memory.items.map((item) => ({
      name: item.name,
      desc: item.desc,
      glyph: memoryGlyphs[item.key] ?? '',
    })),
  },
];
---

<section
  id="features"
  class="feature-trio relative z-30 px-6 pb-28 pt-16 sm:px-10 sm:pb-32 sm:pt-20 lg:px-16 lg:pb-40 lg:pt-24 xl:px-24 2xl:px-32 md:-mt-[100vh]"
  aria-label={t.featureTrio.title[lang]}
>
  <div class="mx-auto max-w-[96vw]">
    <header data-reveal class="mb-14 max-w-2xl sm:mb-16">
      <div
        class="mb-3 inline-flex items-center gap-2 text-[10px] font-semibold uppercase tracking-[0.28em] text-[color:var(--color-muted)]"
      >
        <span class="h-px w-6 bg-[color:var(--color-line-strong)]"></span>
        {t.featureTrio.eyebrow[lang]}
      </div>
      <h2
        class="wordmark-display mb-4 text-[clamp(2rem,4vw,3.4rem)] leading-[1.05] text-[color:var(--color-fg)]"
      >
        {t.featureTrio.title[lang]}
      </h2>
      <p
        class="text-base leading-relaxed text-[color:var(--color-muted)] sm:text-lg"
      >
        {t.featureTrio.body[lang]}
      </p>
    </header>

    <ul
      data-trio-list
      class="trio-list grid grid-cols-1 gap-4 md:gap-3"
    >
      {
        cards.map((card, idx) => (
          <li
            data-trio-card={card.key}
            data-state="rest"
            data-trio-index={idx}
            class="trio-card group relative flex min-h-[400px] cursor-pointer flex-col overflow-hidden rounded-2xl border border-[color:var(--color-line-strong)]/70 bg-[color:var(--color-surface)] p-5 md:h-[38vh] md:p-6 xl:p-7 2xl:p-9"
          >
            <div class="card-vertical pointer-events-none absolute inset-0 hidden flex-col items-center justify-between p-6">
              <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-[color:var(--color-fg)] text-[color:var(--color-surface)]">
                <svg
                  viewBox="0 0 24 24"
                  class="h-[20px] w-[20px]"
                  aria-hidden="true"
                  set:html={pillarIcons[card.key]}
                />
              </span>
              <span class="card-vertical-label text-[10px] font-semibold uppercase tracking-[0.32em] text-[color:var(--color-fg)]">
                {card.meta.kicker[lang]}
              </span>
              <span class="block h-1 w-1 rounded-full bg-[color:var(--color-line-strong)]" />
            </div>

            <div class="card-horizontal relative flex h-full min-h-0 flex-col">
              <div class="flex items-center gap-3 xl:gap-3.5">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-[color:var(--color-fg)] text-[color:var(--color-surface)] transition-transform duration-200 group-hover:scale-[1.03] xl:h-12 xl:w-12 2xl:h-14 2xl:w-14">
                  <svg
                    viewBox="0 0 24 24"
                    class="h-[18px] w-[18px] xl:h-[22px] xl:w-[22px] 2xl:h-[26px] 2xl:w-[26px]"
                    aria-hidden="true"
                    set:html={pillarIcons[card.key]}
                  />
                </span>
                <span class="text-[10px] font-semibold uppercase tracking-[0.28em] text-[color:var(--color-muted)] xl:text-[11px] 2xl:text-[12px]">
                  {card.meta.kicker[lang]}
                </span>
              </div>

              <h3 class="wordmark-display mt-4 text-[clamp(1.1rem,1.5vw,2rem)] leading-[1.1] text-[color:var(--color-fg)] xl:mt-5 2xl:mt-6">
                {card.meta.title[lang]}
              </h3>

              <p class="mt-2 line-clamp-2 text-[clamp(12px,0.9vw,16px)] leading-relaxed text-[color:var(--color-muted)] xl:mt-3 2xl:mt-4">
                {card.meta.body[lang]}
              </p>

              <!-- Items grid:
                   `flex-1 min-h-0` lets this region absorb all the
                   space the header leaves behind, and `auto-rows-fr`
                   + `h-full` makes the 2 implicit rows split that
                   height equally — so when the card height is fixed
                   at 38vh, the items just resize to fit instead of
                   spilling past the bottom. -->
              <div class="card-items-wrap mt-3 flex-1 min-h-0 xl:mt-4 2xl:mt-5">
                <div class="card-items grid h-full auto-rows-fr grid-cols-2 gap-1.5 sm:grid-cols-3 lg:grid-cols-4 xl:gap-2 2xl:gap-2.5">
                  {card.items.map((item) => (
                    <div class="card-item flex min-h-0 items-center gap-2 overflow-hidden rounded-lg border border-[color:var(--color-line-strong)]/50 bg-[color:var(--color-ink-50)]/40 p-2 transition-colors duration-200 hover:bg-[color:var(--color-ink-50)] xl:gap-2.5 xl:p-2.5 2xl:gap-3 2xl:p-3">
                      <span class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-[color:var(--color-surface)] text-[color:var(--color-fg)] xl:h-7 xl:w-7 2xl:h-9 2xl:w-9">
                        <svg
                          viewBox="0 0 24 24"
                          class="h-[12px] w-[12px] xl:h-[14px] xl:w-[14px] 2xl:h-[18px] 2xl:w-[18px]"
                          aria-hidden="true"
                          set:html={item.glyph}
                        />
                      </span>
                      <div class="min-w-0">
                        <div class="line-clamp-1 text-[clamp(11px,0.82vw,14px)] font-semibold tracking-tight text-[color:var(--color-fg)]">
                          {item.name[lang]}
                        </div>
                        <div class="line-clamp-1 text-[clamp(9px,0.68vw,12px)] leading-snug text-[color:var(--color-muted)] xl:line-clamp-2">
                          {item.desc[lang]}
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <div class="card-cue mt-auto flex items-center gap-2 pt-4 text-[11px] font-medium uppercase tracking-[0.22em] text-[color:var(--color-subtle)] md:hidden">
                <span class="h-px w-6 bg-[color:var(--color-line-strong)]" />
                <span>{lang === 'zh' ? '点开展开' : 'Tap to expand'}</span>
              </div>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  /* The container drives width via animated grid-template-columns on md+.
     Animating grid tracks lets the browser plan the whole row's layout in
     one pass per frame, instead of resolving per-card flex-grow each frame
     (which is what produced the visible stutter). */
  .trio-list {
    align-items: stretch;
  }

  .trio-card {
    /* `contain: layout style` isolates each card's internal layout
       from siblings — reflowing text inside one card (which happens
       continuously as its width animates) no longer triggers a layout
       pass on the OTHER cards. This is the single biggest contributor
       to perceived smoothness during the column-width animation. */
    contain: layout style;
    transition:
      background-color 280ms ease,
      border-color 280ms ease;
  }

  @media (min-width: 768px) {
    .trio-list {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 0.75rem;
      /* `will-change` keeps the grid track values on the compositor's
         fast path. Permanent (not toggled per-hover) so transitions
         start clean on the very first interaction with no warm-up. */
      will-change: grid-template-columns;
      /* Shortened from 880ms → 620ms — long durations on layout
         properties read as "drag/sluggish" because the eye expects
         interactive feedback to settle in ≤700ms. The new ease
         (expo-out) puts more travel up front and a gentle tail, which
         hides any residual frame variance at the seam. */
      transition: grid-template-columns 620ms cubic-bezier(0.16, 1, 0.3, 1);
    }
    .trio-list[data-active='tools'] {
      grid-template-columns: 3.4fr 0.55fr 0.55fr;
    }
    .trio-list[data-active='channels'] {
      grid-template-columns: 0.55fr 3.4fr 0.55fr;
    }
    .trio-list[data-active='memory'] {
      grid-template-columns: 0.55fr 0.55fr 3.4fr;
    }
    .trio-card {
      min-width: 0;
    }
    .trio-card[data-state='active'] {
      background-color: var(--color-ink-50);
      border-color: var(--color-fg);
    }
    .trio-card[data-state='strip'] {
      background-color: var(--color-surface);
    }
  }

  /* Items grid is always rendered (just hidden via opacity in resting
     state) so the card height does NOT change between rest/active.
     Only width animates — that's the requested behaviour. The visible
     reveal is a slow fade + slight rise, started after the column has
     already begun widening. */
  .card-items-wrap {
    margin-top: 1rem;
  }
  /* Asymmetric transitions: the DEFAULT (= leaving-active) is fast so
     items don't linger as the card narrows. The [data-state="active"]
     rule overrides with a slower, slightly-delayed reveal so items
     materialize AS the column finishes widening, not after. */
  .card-items {
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 200ms ease,
      transform 240ms ease;
    pointer-events: none;
  }
  .trio-card[data-state='active'] .card-items {
    opacity: 1;
    transform: none;
    transition:
      opacity 360ms ease 120ms,
      transform 440ms cubic-bezier(0.16, 1, 0.3, 1) 120ms;
    pointer-events: auto;
  }
  /* When this card is squeezed into a strip, hide the items grid
     completely so it doesn't peek through the vertical layout. */
  .trio-card[data-state='strip'] .card-items {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 200ms ease;
  }

  /* When a sibling is active and this card is squeezed, collapse the
     horizontal content and show the vertical layout instead. The strip
     fade is delayed a touch so the column has visibly started narrowing
     before the content cross-fades — keeps it from feeling abrupt. */
  @media (min-width: 768px) {
    .card-horizontal {
      transition: opacity 260ms ease;
    }
    .trio-card[data-state='strip'] .card-horizontal {
      opacity: 0;
      pointer-events: none;
      transition: opacity 240ms ease 40ms;
    }
    .card-vertical {
      opacity: 0;
      transition: opacity 240ms ease;
    }
    .trio-card[data-state='strip'] .card-vertical {
      display: flex;
      opacity: 1;
      transition: opacity 240ms ease 180ms;
    }
  }

  /* Cue line under each resting card — fades out in strip/active states. */
  .card-cue {
    opacity: 1;
    transition: opacity 260ms ease;
  }
  .trio-card[data-state='active'] .card-cue,
  .trio-card[data-state='strip'] .card-cue {
    opacity: 0;
  }

  /* Mobile / coarse pointer: stack vertically, items grid only renders for
     the currently active card so resting cards stay compact. On md+ the
     items grid is always in flow (just hidden via opacity) so the card
     height never changes — that's the whole point on desktop. */
  @media (max-width: 767px) {
    .trio-card:not([data-state='active']) .card-items-wrap {
      display: none;
    }
  }
</style>
