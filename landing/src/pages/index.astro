---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ZoomSection from '../components/ZoomSection.astro';
import FeatureTrio from '../components/FeatureTrio.astro';
import UseCases from '../components/UseCases.astro';
import ProviderStrip from '../components/ProviderStrip.astro';
import Install from '../components/Install.astro';
import Footer from '../components/Footer.astro';

const lang = 'zh';
---

<BaseLayout lang={lang}>
  <Hero lang={lang} />
  <ZoomSection lang={lang} />
  <FeatureTrio lang={lang} />
  <UseCases lang={lang} />
  <ProviderStrip lang={lang} />
  <Install lang={lang} />
  <Footer lang={lang} />
</BaseLayout>
